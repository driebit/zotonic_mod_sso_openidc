%% -*- mode: erlang -*-

{minimum_otp_vsn, "26"}.

{erl_opts, [
    debug_info
]}.

{deps,
 [
   zotonic_core,
   {oidcc, "~> 3.2.0"}
 ]
}.

{plugins, []}.

{xref_checks, [undefined_function_calls,
               locals_not_used,
               deprecated_function_calls]}.

{project_plugins, [rebar3_ex_doc]}.
{hex, [{doc, ex_doc}]}.
